# ==============================================================================
# OutPace B2B Intelligence - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control - it contains secrets!
# ==============================================================================

# ==============================================================================
# REQUIRED - Server will NOT start without these
# ==============================================================================

# MongoDB connection string (use authenticated connection in production)
MONGO_URL=mongodb://user:password@localhost:27017/outpace_intelligence

# Database name
DB_NAME=outpace_intelligence

# JWT signing key - MUST be unique and secure in production
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ==============================================================================
# ENVIRONMENT & SECURITY
# ==============================================================================

# Environment mode: "development" or "production"
# In production: CORS wildcards are blocked, stricter security checks apply
ENV=development

# Allowed CORS origins (comma-separated)
# In production: Set to your actual domain(s), NEVER use * or localhost
CORS_ORIGINS=http://localhost:3000

# ==============================================================================
# DOCKER COMPOSE - MongoDB Initialization
# ==============================================================================

# MongoDB root credentials (used by docker-compose for initial setup)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_strong_password_here

# Application database user (created by mongo-init.js)
MONGO_APP_USERNAME=outpace_app
MONGO_APP_PASSWORD=CHANGE_ME_strong_password_here

# ==============================================================================
# RATE LIMITING
# ==============================================================================

# Rate limit storage backend
# Development: memory:// (resets on restart, per-instance limits)
# Production: redis://redis:6379/0 (persistent, shared across instances)
RATE_LIMIT_STORAGE=memory://

# Rate limits (requests per time window)
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=20/minute

# ==============================================================================
# SECRETS MANAGEMENT
# ==============================================================================

# Secrets backend: "env" (default), "gcp", "aws", or "vault"
# In production: Use a proper secrets manager (gcp, aws, or vault)
SECRETS_BACKEND=env

# GCP Secret Manager (if SECRETS_BACKEND=gcp)
# GCP_PROJECT_ID=your-gcp-project-id

# AWS Secrets Manager (if SECRETS_BACKEND=aws)
# AWS_REGION=us-east-1

# HashiCorp Vault (if SECRETS_BACKEND=vault)
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=your-vault-token

# ==============================================================================
# EXTERNAL API KEYS
# ==============================================================================

# HigherGov API (contract opportunities)
HIGHERGOV_API_KEY=<set-your-highergov-api-key>

# Mistral AI (opportunity scoring, chat)
MISTRAL_API_KEY=your-mistral-api-key

# Perplexity AI (intelligence reports) - Optional
# PERPLEXITY_API_KEY=your-perplexity-api-key

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================

# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256

# Access token expiration in hours (default: 24)
JWT_EXPIRATION_HOURS=24

# Refresh token expiration in days (default: 30)
JWT_REFRESH_EXPIRATION_DAYS=30

# ==============================================================================
# LOGGING
# ==============================================================================

# Log format: "json" (cloud-native) or "text" (human-readable for local dev)
LOG_FORMAT=json

# Enable file logging (local development only - containers are ephemeral)
LOG_TO_FILE=false

# ==============================================================================
# ERROR NOTIFICATIONS (Optional)
# ==============================================================================

# SMTP settings for error email alerts
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=alerts@example.com
# ERROR_NOTIFICATION_TO=ops@example.com

# ==============================================================================
# OPENTELEMETRY / APM (Optional)
# ==============================================================================

# Enable OpenTelemetry tracing
# OTEL_ENABLED=true

# OTLP endpoint for traces/metrics
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name for APM
# OTEL_SERVICE_NAME=outpace-api

# Sampling ratio (0.0 to 1.0, default: 1.0 = all traces)
# OTEL_TRACES_SAMPLER_ARG=1.0

# Test credential variables (local/CI)
CARFAX_ADMIN_EMAIL=admin@your-domain.com
CARFAX_ADMIN_PASSWORD=REPLACE_WITH_TEST_PASSWORD
CARFAX_TENANT_A_EMAIL=tenant-a@test.com
CARFAX_TENANT_A_PASSWORD=REPLACE_WITH_TEST_PASSWORD
CARFAX_TENANT_B_EMAIL=tenant-b@test.com
CARFAX_TENANT_B_PASSWORD=REPLACE_WITH_TEST_PASSWORD
CARFAX_TENANT_A_ADMIN_PASSWORD=REPLACE_WITH_TEST_PASSWORD
E2E_ADMIN_EMAIL=admin@your-domain.com
E2E_ADMIN_PASSWORD=REPLACE_WITH_TEST_PASSWORD

# CORS allowlist (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000
