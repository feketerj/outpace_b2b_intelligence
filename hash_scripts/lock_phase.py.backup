#!/usr/bin/env python3
"""
DACE v1.7.8 - Phase Locking Script
Copies verified artifacts to artifacts_locked/phase_N/ and updates Claude permissions.

Usage:
    python lock_phase.py <phase_number> [--artifacts-dir PATH] [--reports-dir PATH]

Example:
    python lock_phase.py 4
    python lock_phase.py 2 --artifacts-dir ./artifacts --reports-dir ./reports
"""
import argparse
import json
import shutil
import sys
from datetime import datetime
from pathlib import Path


# Define what each phase produces
PHASE_OUTPUTS = {
    1: {
        "artifacts": ["PRD.md"],
        "reports": []
    },
    2: {
        "artifacts": [
            "requirements_protocol.json",
            "requirements_product_core.json",
            "requirements_backend.json",
            "requirements_ui.json",
            "requirements_data.json",
            "requirements_nonfunctional.json",
            "requirements_acceptance.json",
            "requirements_verification.json",
            "resources_manifest.json"
        ],
        "reports": []
    },
    3: {
        "artifacts": [],
        "reports": ["asset_validation.json"]
    },
    4: {
        "artifacts": [
            "harmonized_requirements_protocol.json",
            "harmonized_requirements_product_core.json",
            "harmonized_requirements_backend.json",
            "harmonized_requirements_ui.json",
            "harmonized_requirements_data.json",
            "harmonized_requirements_nonfunctional.json",
            "harmonized_requirements_acceptance.json",
            "harmonized_requirements_verification.json",
            "harmonized_resources_manifest.json"
        ],
        "reports": ["terminology_harmonization.json"]
    },
    5: {
        "artifacts": ["stack_recommendations.json"],
        "reports": ["stack_selection.json"]
    },
    6: {
        "artifacts": ["requirements_protocol.json"],
        "reports": ["protocol_specification.json"]
    },
    7: {
        "artifacts": ["contracts.json"],
        "reports": []
    },
    8: {
        "artifacts": ["stack.json"],
        "reports": ["stack_specification.json"]
    },
    9: {
        "artifacts": ["tasks.json"],
        "reports": ["task_decomposition.json"]
    },
    10: {
        "artifacts": ["testing_strategy.json"],
        "reports": ["testing_strategy.json"]
    },
    11: {
        "artifacts": ["traceability_matrix.json"],
        "reports": ["traceability_matrix.json"]
    },
    12: {
        "artifacts": ["scaffold_manifest.json", "chunk_1_framework.py", "chunk_2_artifacts.py", "chunk_3_validation.py", "assemble_scaffold.py", "scaffold.py"],
        "reports": ["scaffold_manifest.json"]
    },
    13: {
        "artifacts": [],
        "reports": ["quality_gates.json"]
    },
    14: {
        "artifacts": ["repo_manifest.json"],
        "reports": ["repo_manifest.json"]
    }
}


def update_claude_permissions(settings_path: Path) -> bool:
    """
    Update .claude/settings.local.json to deny writes to artifacts_locked/.
    """
    if not settings_path.exists():
        # Create default settings
        settings = {
            "permissions": {
                "allow": [
                    "Bash(*)",
                    "Read(*)",
                    "Write(artifacts/*)",
                    "Write(reports/*)",
                    "Write(run_log.json)",
                    "Edit(artifacts/*)",
                    "Edit(reports/*)"
                ],
                "deny": [],
                "ask": []
            }
        }
    else:
        try:
            settings = json.loads(settings_path.read_text(encoding='utf-8'))
        except json.JSONDecodeError:
            print(f"[ERROR] Invalid JSON in {settings_path}")
            return False

    # Ensure structure exists
    if "permissions" not in settings:
        settings["permissions"] = {"allow": [], "deny": [], "ask": []}
    if "deny" not in settings["permissions"]:
        settings["permissions"]["deny"] = []

    # Add deny rules for artifacts_locked if not present
    deny_rules = [
        "Write(artifacts_locked/*)",
        "Edit(artifacts_locked/*)"
    ]

    for rule in deny_rules:
        if rule not in settings["permissions"]["deny"]:
            settings["permissions"]["deny"].append(rule)

    # Write back
    settings_path.parent.mkdir(parents=True, exist_ok=True)
    settings_path.write_text(json.dumps(settings, indent=2), encoding='utf-8')

    return True


def lock_phase(
    phase: int,
    artifacts_dir: Path,
    reports_dir: Path,
    locked_base: Path,
    settings_path: Path
) -> bool:
    """
    Lock a phase by copying its outputs to artifacts_locked/phase_N/.
    """
    if phase not in PHASE_OUTPUTS:
        print(f"[ERROR] Unknown phase: {phase}")
        print(f"Valid phases: {list(PHASE_OUTPUTS.keys())}")
        return False

    phase_config = PHASE_OUTPUTS[phase]
    locked_dir = locked_base / f"phase_{phase}"

    print("=" * 60)
    print(f"DACE v1.7.8 - Locking Phase {phase}")
    print("=" * 60)
    print(f"\nTarget: {locked_dir}\n")

    # Create locked directory
    locked_dir.mkdir(parents=True, exist_ok=True)

    copied_count = 0
    missing = []

    # Copy artifacts
    for filename in phase_config["artifacts"]:
        src = artifacts_dir / filename
        dst = locked_dir / filename

        if src.exists():
            shutil.copy2(src, dst)
            print(f"  [LOCKED] {filename}")
            copied_count += 1
        else:
            missing.append(f"artifacts/{filename}")

    # Copy reports
    for filename in phase_config["reports"]:
        src = reports_dir / filename
        dst = locked_dir / filename

        if src.exists():
            shutil.copy2(src, dst)
            print(f"  [LOCKED] {filename}")
            copied_count += 1
        else:
            missing.append(f"reports/{filename}")

    if missing:
        print("\n[WARNING] Missing files:")
        for f in missing:
            print(f"  - {f}")

    # Write lock manifest
    manifest = {
        "phase": phase,
        "locked_at": datetime.now().isoformat() + "Z",
        "files": phase_config["artifacts"] + phase_config["reports"],
        "copied": copied_count,
        "missing": missing
    }

    manifest_path = locked_dir / "_lock_manifest.json"
    manifest_path.write_text(json.dumps(manifest, indent=2), encoding='utf-8')
    print("\n  [MANIFEST] _lock_manifest.json")

    # Update Claude permissions
    print(f"\n[PERMISSIONS] Updating {settings_path}...")
    if update_claude_permissions(settings_path):
        print("  [OK] Deny rules added for artifacts_locked/*")
    else:
        print("  [WARN] Failed to update permissions")

    # Summary
    print("\n" + "-" * 60)
    print(f"Phase {phase} locked: {copied_count} files copied")
    if missing:
        print(f"[WARNING] {len(missing)} files missing - phase may be incomplete")
    print("-" * 60)

    return len(missing) == 0


def main():
    parser = argparse.ArgumentParser(
        description="Lock DACE phase artifacts for rollback protection"
    )
    parser.add_argument(
        "phase",
        type=int,
        help="Phase number to lock (1-14)"
    )
    parser.add_argument(
        "--artifacts-dir",
        type=Path,
        default=Path("./artifacts"),
        help="Path to artifacts directory (default: ./artifacts)"
    )
    parser.add_argument(
        "--reports-dir",
        type=Path,
        default=Path("./reports"),
        help="Path to reports directory (default: ./reports)"
    )
    parser.add_argument(
        "--locked-dir",
        type=Path,
        default=Path("./artifacts_locked"),
        help="Path to locked artifacts base (default: ./artifacts_locked)"
    )
    parser.add_argument(
        "--settings",
        type=Path,
        default=Path("./.claude/settings.local.json"),
        help="Path to Claude settings file"
    )

    args = parser.parse_args()

    success = lock_phase(
        phase=args.phase,
        artifacts_dir=args.artifacts_dir,
        reports_dir=args.reports_dir,
        locked_base=args.locked_dir,
        settings_path=args.settings
    )

    sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()










