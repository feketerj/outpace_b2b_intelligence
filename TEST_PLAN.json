{
  "test_plan": "OutPace Carfax Test Plan",
  "as_of": "2025-12-18",
  "environments": {
    "base_url": "https://tenant-api-repair.preview.emergentagent.com"
  },
  "principles": [
    "Evidence-first: every test records curl + HTTP code + key log/db checks",
    "Deterministic: explicit setup/teardown where needed",
    "One failure class per test",
    "No silent pass: every test has explicit PASS criteria"
  ],
  "fixtures": {
    "super_admin": { "email": "admin@example.com", "password": "REDACTED_ADMIN_PASSWORD" },
    "tenant_a_user": { "email": "tenant-test@test.com", "password": "REDACTED_TEST_PASSWORD" },
    "tenant_b_user": { "email": "tenant-b-test@test.com", "password": "REDACTED_TEST_PASSWORD" },
    "tenant_a_id": "bec8a414-b00d-4a58-9539-5f732db23b35",
    "tenant_b_id": "8aa521eb-56ad-4727-8f09-c01fc7921c21"
  },
  "suites": [
    {
      "name": "S0_smoke",
      "run_time_target_sec": 120,
      "tests": [
        { "id": "S0-01", "name": "login_super_admin", "steps": ["POST /api/auth/login"], "assert": ["200", "access_token present"] },
        { "id": "S0-02", "name": "login_tenant_user", "steps": ["POST /api/auth/login"], "assert": ["200", "access_token present"] },
        { "id": "S0-03", "name": "auth_me", "steps": ["GET /api/auth/me"], "assert": ["200", "role and tenant_id present"] },
        { "id": "S0-04", "name": "list_opportunities", "steps": ["GET /api/opportunities"], "assert": ["200"] },
        { "id": "S0-05", "name": "list_intelligence", "steps": ["GET /api/intelligence"], "assert": ["200"] },
        { "id": "S0-06", "name": "health", "steps": ["GET /health"], "assert": ["200"] }
      ]
    },
    {
      "name": "S1_invariants_tenant_isolation",
      "tests": [
        {
          "id": "ISO-01",
          "name": "cross_tenant_get_opportunity_403",
          "setup": ["Tenant A: GET /api/opportunities -> pick opp_id"],
          "steps": ["Tenant B: GET /api/opportunities/{opp_id}"],
          "assert": ["HTTP 403", "body.detail == 'Access denied'"],
          "invariants": ["INV-1"]
        },
        {
          "id": "ISO-02",
          "name": "cross_tenant_get_intelligence_403",
          "setup": ["Tenant A: GET /api/intelligence -> pick intel_id"],
          "steps": ["Tenant B: GET /api/intelligence/{intel_id}"],
          "assert": ["HTTP 403", "body.detail == 'Access denied'"],
          "invariants": ["INV-1"]
        },
        {
          "id": "ISO-03",
          "name": "cross_tenant_export_pdf_403",
          "setup": ["Tenant A: pick opp_id"],
          "steps": ["Tenant B: POST /api/exports/pdf with tenant_id=TenantA and opp_id"],
          "assert": ["HTTP 403"],
          "invariants": ["INV-1", "INV-5"]
        },
        {
          "id": "ISO-04",
          "name": "cross_tenant_rag_nonleak_audit",
          "setup": [
            "Enable rag_policy for Tenant B",
            "Tenant A has chunks; Tenant B has 0 chunks"
          ],
          "steps": [
            "Tenant B: POST /api/chat/message ask about Tenant A canary",
            "Tail logs for [rag.audit] tenant_id=TenantB reason=no_chunks used=0"
          ],
          "assert": ["[rag.audit] line exists with tenant_id=TenantB and used=0"],
          "invariants": ["INV-1"]
        }
      ]
    },
    {
      "name": "S2_chat_gating_atomicity_quota",
      "tests": [
        {
          "id": "CHAT-01",
          "name": "chat_disabled_403_no_persist",
          "setup": ["Super admin: set tenant.chat_policy.enabled=false", "Reset chat_usage"],
          "steps": ["Tenant: POST /api/chat/message"],
          "assert": ["HTTP 403", "DB chat_turns count for conv == 0"],
          "invariants": ["INV-3", "INV-2"]
        },
        {
          "id": "CHAT-02",
          "name": "quota_limit_429_no_persist",
          "setup": ["Super admin: monthly_message_limit=1", "Reset chat_usage"],
          "steps": ["Tenant: send message -> 200", "Tenant: send second message -> 429"],
          "assert": ["Second HTTP 429", "DB chat_turns count for blocked conv == 0"],
          "invariants": ["INV-2"]
        },
        {
          "id": "CHAT-03",
          "name": "quota_concurrency_1_success_rest_429",
          "setup": ["monthly_message_limit=1", "Reset chat_usage"],
          "steps": ["Send N=10 parallel POST /api/chat/message"],
          "assert": ["Exactly 1 HTTP 200 and N-1 HTTP 429", "DB chat_turns created == 1"],
          "invariants": ["INV-2"]
        },
        {
          "id": "CHAT-04",
          "name": "atomicity_on_llm_failure",
          "setup": ["Force LLM failure (invalid key or service unavailable)"],
          "steps": ["Count chat_turns BEFORE", "POST /api/chat/message -> failure", "Count chat_turns AFTER"],
          "assert": ["AFTER == BEFORE"],
          "invariants": ["INV-2"]
        },
        {
          "id": "CHAT-05",
          "name": "input_guardrails_conversation_id",
          "steps": [
            "POST /api/chat/message with conversation_id containing spaces -> 400",
            "POST /api/chat/message with conversation_id length > 128 -> 400"
          ],
          "assert": ["HTTP 400 for each"],
          "invariants": ["INV-2"]
        }
      ]
    },
    {
      "name": "S3_patch_whitelists_audit",
      "tests": [
        {
          "id": "PATCH-OPP-01",
          "name": "opportunity_patch_ignored_logged",
          "setup": ["Get opp_id as tenant"],
          "steps": ["PATCH /api/opportunities/{opp_id} with allowed client_status + forbidden score + tenant_id"],
          "assert": [
            "HTTP 200",
            "Log contains [audit.patch_ignored] endpoint=opportunities fields includes score and tenant_id",
            "GET opp shows score unchanged"
          ],
          "invariants": ["INV-1"]
        },
        {
          "id": "PATCH-INTEL-01",
          "name": "intelligence_patch_ignored_logged",
          "setup": ["Get intel_id as tenant"],
          "steps": ["PATCH /api/intelligence/{intel_id} with allowed client_notes + forbidden score + tenant_id"],
          "assert": [
            "HTTP 200",
            "Log contains [audit.patch_ignored] endpoint=intelligence fields includes score and tenant_id",
            "GET intel shows no score field"
          ],
          "invariants": ["INV-1"]
        },
        {
          "id": "PATCH-TAGS-01",
          "name": "opportunity_tags_contract",
          "setup": ["Get opp_id"],
          "steps": ["PATCH tags -> ignored+logged", "PATCH client_tags -> stored"],
          "assert": ["tags ignored", "client_tags persists"],
          "notes": "Ensures contract is stable for clients/integrations."
        }
      ]
    },
    {
      "name": "S4_rag_admin_ingestion_retrieval_integrity",
      "tests": [
        {
          "id": "RAG-01",
          "name": "ingest_canary_retrieves",
          "setup": ["Super admin enables rag_policy for Tenant A with capacity"],
          "steps": [
            "POST /api/tenants/{tenantA}/rag/documents with unique phrase",
            "Tenant A chat asks about phrase",
            "Assert response includes seeded content OR rag.audit shows success used>0"
          ],
          "assert": ["HTTP 200 ingest", "[rag.audit] reason=success used>0"]
        },
        {
          "id": "RAG-02",
          "name": "capacity_enforcement_409",
          "setup": ["Set rag_policy.max_chunks low"],
          "steps": ["POST document large enough to exceed chunk limit"],
          "assert": ["HTTP 409", "detail mentions chunk limit"]
        },
        {
          "id": "RAG-03",
          "name": "startup_cleanup_processing_docs",
          "setup": ["Insert fake kb_document status=processing older than threshold + a chunk"],
          "steps": ["Restart backend", "Check logs for [rag.cleanup]", "Verify DB removed doc+chunks"],
          "assert": ["doc_count==0", "chunk_count==0"]
        },
        {
          "id": "RAG-04",
          "name": "indexes_ensured_on_startup",
          "steps": ["Restart backend", "grep logs for [rag.indexes]"],
          "assert": ["[rag.indexes] present"]
        }
      ]
    },
    {
      "name": "S5_master_tenant_restrictions",
      "tests": [
        {
          "id": "MASTER-01",
          "name": "master_blocks_chat_policy",
          "setup": ["Find master tenant id as super_admin"],
          "steps": ["PUT /api/tenants/{master} with chat_policy"],
          "assert": ["HTTP 403", "detail contains 'chat_policy cannot be modified'"],
          "invariants": ["INV-4"]
        },
        {
          "id": "MASTER-02",
          "name": "master_blocks_rag_policy",
          "setup": ["Find master tenant id as super_admin"],
          "steps": ["PUT /api/tenants/{master} with rag_policy"],
          "assert": ["HTTP 403", "detail contains 'rag_policy cannot be modified'"],
          "invariants": ["INV-4"]
        },
        {
          "id": "MASTER-03",
          "name": "master_blocks_tenant_knowledge",
          "setup": ["Find master tenant id as super_admin"],
          "steps": ["PUT /api/tenants/{master} with tenant_knowledge"],
          "assert": ["HTTP 403", "detail contains 'tenant_knowledge cannot be modified'"],
          "invariants": ["INV-4"]
        }
      ]
    },
    {
      "name": "S6_exports_determinism",
      "tests": [
        { "id": "EXP-01", "name": "empty_selection_404_pdf", "steps": ["POST /api/exports/pdf with empty ids"], "assert": ["HTTP 404"] },
        { "id": "EXP-02", "name": "nonexistent_ids_404_pdf", "steps": ["POST /api/exports/pdf with bogus id"], "assert": ["HTTP 404"] },
        { "id": "EXP-03", "name": "missing_tenant_id_super_admin_400", "steps": ["Super admin POST /api/exports/pdf without tenant_id"], "assert": ["HTTP 400"] },
        { "id": "EXP-04", "name": "valid_export_has_headers", "setup": ["Pick valid opp/intel ids"], "steps": ["POST /api/exports/pdf"], "assert": ["HTTP 200", "Content-Type application/pdf", "Content-Disposition attachment"] }
      ]
    },
    {
      "name": "S7_integrations_sync",
      "tests": [
        {
          "id": "SYNC-01",
          "name": "manual_sync_endpoint_super_admin_only",
          "steps": [
            "Tenant_user calls POST /api/sync/manual/{tenant_id} -> 403",
            "Super_admin calls POST /api/sync/manual/{tenant_id} -> 200/202"
          ],
          "assert": ["tenant_user forbidden", "super_admin allowed"]
        },
        {
          "id": "SYNC-02",
          "name": "admin_trigger_sync_super_admin_only",
          "steps": [
            "Tenant_user calls POST /api/admin/sync/{tenant_id} -> 403",
            "Super_admin calls POST /api/admin/sync/{tenant_id} -> 200"
          ],
          "assert": ["tenant_user forbidden", "super_admin allowed"]
        },
        {
          "id": "SYNC-03",
          "name": "scheduler_starts_on_boot",
          "steps": ["restart backend", "tail logs for 'Scheduler started successfully'"],
          "assert": ["scheduler started line present"]
        }
      ]
    },
    {
      "name": "S8_upload_branding",
      "tests": [
        {
          "id": "UPLOAD-01",
          "name": "tenant_logo_upload_super_admin_only",
          "steps": [
            "Tenant_user POST /api/upload/logo/{tenant_id} -> 403",
            "Super_admin POST /api/upload/logo/{tenant_id} -> 200"
          ],
          "assert": ["tenant_user forbidden", "super_admin allowed"]
        },
        {
          "id": "UPLOAD-02",
          "name": "opportunities_csv_upload_super_admin_only",
          "steps": [
            "Tenant_user POST /api/upload/opportunities/csv/{tenant_id} -> 403",
            "Super_admin POST /api/upload/opportunities/csv/{tenant_id} -> 200"
          ],
          "assert": ["tenant_user forbidden", "super_admin allowed"]
        }
      ]
    },
    {
      "name": "S9_cf_config",
      "tests": [
        {
          "id": "CF-CONFIG-PERSIST",
          "name": "config_update_persistence",
          "setup": ["Get current tenant config"],
          "steps": [
            "Update tenant chat_policy.enabled",
            "Retrieve config after update",
            "Verify intended change persisted"
          ],
          "assert": ["HTTP 200", "config after update == config before + intended change"],
          "notes": "Ensures configuration updates are properly persisted"
        },
        {
          "id": "CF-CONFIG-NON-DESTRUCTIVE", 
          "name": "nested_field_update_preserves_siblings",
          "setup": ["Get full tenant config with multiple fields"],
          "steps": [
            "Update only chat_policy field",
            "Retrieve config after update", 
            "Verify other fields (name, rag_policy) unchanged"
          ],
          "assert": ["HTTP 200", "sibling fields preserved", "target field updated"],
          "notes": "Ensures partial updates don't remove unrelated configuration"
        }
      ]
    }
  ]
}
