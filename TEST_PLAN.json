      "name": "Master Tenant Restriction",
      "statement": "is_master_client=true cannot modify chat_policy, rag_policy, tenant_knowledge via API",
      "criticality": "HIGH",
      "test_approach": "PUT master tenant with forbidden fields, verify 403"
    },
    {
      "id": "INV-5",
      "name": "Export Determinism",
      "statement": "Export returns a valid file or fails loudly; no silent corrupt outputs",
      "criticality": "MEDIUM",
