{
  "app": "OutPace Intelligence Platform",
  "as_of": "2025-12-18",
  "inventory_source": {
    "backend_routes_runtime": "python3 from server import app; print(app.routes)",
    "backend_grep": "grep -RIn (HigherGov|Perplexity|Mistral|sync|scheduler|upload|branding|logo|master_branding)",
    "frontend_pages": "frontend/src/pages/*.js"
  },
  "roles": {
    "super_admin": {
      "description": "Control plane. Can manage tenants/users/config and trigger sync. Can view tenant data via tenant_id parameter where supported."
    },
    "tenant_user": {
      "description": "Consumption plane. Tenant-scoped access to opps/intel/chat/exports/preview."
    }
  },
  "global_invariants": [
    {
      "id": "INV-1",
      "name": "tenant_isolation",
      "statement": "Tenant cannot read/patch/export/chat/RAG other tenant data. Cross-tenant attempts return 403 or equivalent."
    },
    {
      "id": "INV-2",
      "name": "chat_atomicity",
      "statement": "On any failure (LLM/embeddings/DB/quota), no ChatTurn persists."
    },
    {
      "id": "INV-3",
      "name": "paid_chat_enforcement",
      "statement": "chat_policy.enabled=false => 403 and no persistence."
    },
    {
      "id": "INV-4",
      "name": "master_tenant_restriction",
      "statement": "is_master_client=true cannot update chat_policy, rag_policy, tenant_knowledge."
    },
    {
      "id": "INV-5",
      "name": "export_determinism",
      "statement": "Export returns valid file OR loud failure (400/403/404). No silent corrupt output."
    }
  ],
  "observability": {
    "log_tags": [
      "[rag.audit]",
      "[tenant.audit]",
      "[audit.patch_ignored]",
      "[quota]",
      "[knowledge]",
      "[rag.cleanup]",
      "[rag.indexes]"
    ],
    "runbook": "/app/FAILURE_MODES_RUNBOOK.md"
  },
  "backend_endpoints": [
    {
      "domain": "auth",
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/auth/login",
          "name": "login",
          "roles_allowed": ["super_admin", "tenant_user"],
          "success": { "status": 200, "returns": ["access_token"] },
          "failures": [{ "status": 401, "when": "invalid_credentials" }]
        },
        {
          "method": "POST",
          "path": "/api/auth/register",
          "name": "register",
          "roles_allowed": ["super_admin", "tenant_user"],
          "notes": "Present in route inventory; validate intended access policy.",
          "success": { "status": 200 },
          "failures": [{ "status": 400, "when": "validation_or_duplicate" }]
        },
        {
          "method": "GET",
          "path": "/api/auth/me",
          "name": "get_current_user_info",
          "roles_allowed": ["super_admin", "tenant_user"],
          "success": { "status": 200, "returns": ["role", "tenant_id"] },
          "failures": [{ "status": 401, "when": "missing_or_invalid_token" }]
        }
      ]
    },
    {
      "domain": "admin",
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/admin/dashboard",
          "name": "get_admin_dashboard",
          "roles_allowed": ["super_admin"]
        },
        {
          "method": "GET",
          "path": "/api/admin/system/health",
          "name": "check_system_health",
          "roles_allowed": ["super_admin"]
        },
        {
          "method": "POST",
          "path": "/api/admin/sync/{tenant_id}",
          "name": "trigger_manual_sync",
          "roles_allowed": ["super_admin"]
        }
      ]
    },
    {
      "domain": "tenants",
      "endpoints": [
        { "method": "GET", "path": "/api/tenants", "name": "list_tenants", "roles_allowed": ["super_admin"] },
        { "method": "POST", "path": "/api/tenants", "name": "create_tenant", "roles_allowed": ["super_admin"] },
        { "method": "GET", "path": "/api/tenants/{tenant_id}", "name": "get_tenant", "roles_allowed": ["super_admin"] },
        {
          "method": "PUT",
          "path": "/api/tenants/{tenant_id}",
          "name": "update_tenant",
          "roles_allowed": ["super_admin"],
          "constraints": [
            { "if": "tenant.is_master_client==true", "forbid_fields": ["chat_policy", "rag_policy", "tenant_knowledge"], "status": 403 }
          ],
          "invariants": ["INV-4"]
        },
        { "method": "DELETE", "path": "/api/tenants/{tenant_id}", "name": "delete_tenant", "roles_allowed": ["super_admin"], "success": { "status": 204 } }
      ]
    },
    {
      "domain": "users",
      "endpoints": [
        { "method": "GET", "path": "/api/users", "name": "list_users", "roles_allowed": ["super_admin"] },
        { "method": "POST", "path": "/api/users", "name": "create_user", "roles_allowed": ["super_admin"] },
        { "method": "GET", "path": "/api/users/{user_id}", "name": "get_user", "roles_allowed": ["super_admin"] },
        { "method": "PUT", "path": "/api/users/{user_id}", "name": "update_user", "roles_allowed": ["super_admin"] },
        { "method": "DELETE", "path": "/api/users/{user_id}", "name": "delete_user", "roles_allowed": ["super_admin"], "success": { "status": 204 } }
      ]
    },
    {
      "domain": "opportunities",
      "endpoints": [
        { "method": "GET", "path": "/api/opportunities", "name": "list_opportunities", "roles_allowed": ["tenant_user", "super_admin"], "invariants": ["INV-1"] },
        { "method": "POST", "path": "/api/opportunities", "name": "create_opportunity", "roles_allowed": ["tenant_user", "super_admin"], "invariants": ["INV-1"] },
        { "method": "GET", "path": "/api/opportunities/{opp_id}", "name": "get_opportunity", "roles_allowed": ["tenant_user", "super_admin"], "failures": [{ "status": 403, "when": "cross_tenant" }], "invariants": ["INV-1"] },
        {
          "method": "PATCH",
          "path": "/api/opportunities/{opp_id}",
          "name": "update_opportunity_status",
          "roles_allowed": ["tenant_user"],
          "allowed_fields": ["client_status", "client_notes", "client_tags", "is_archived"],
          "ignored_fields_behavior": "silently_ignored_and_logged",
          "logs": ["[audit.patch_ignored]", "[tenant.audit]"],
          "invariants": ["INV-1"]
        },
        { "method": "DELETE", "path": "/api/opportunities/{opp_id}", "name": "delete_opportunity", "roles_allowed": ["tenant_user", "super_admin"], "invariants": ["INV-1"] },
        { "method": "GET", "path": "/api/opportunities/stats/{tenant_id}", "name": "get_opportunity_stats", "roles_allowed": ["tenant_user", "super_admin"], "invariants": ["INV-1"] }
      ]
    },
    {
      "domain": "intelligence",
      "endpoints": [
        { "method": "GET", "path": "/api/intelligence", "name": "list_intelligence", "roles_allowed": ["tenant_user", "super_admin"], "invariants": ["INV-1"] },
        { "method": "POST", "path": "/api/intelligence", "name": "create_intelligence", "roles_allowed": ["tenant_user", "super_admin"], "invariants": ["INV-1"] },
        { "method": "GET", "path": "/api/intelligence/{intel_id}", "name": "get_intelligence", "roles_allowed": ["tenant_user", "super_admin"], "failures": [{ "status": 403, "when": "cross_tenant" }], "invariants": ["INV-1"] },
        {
          "method": "PATCH",
          "path": "/api/intelligence/{intel_id}",
          "name": "update_intelligence",
          "roles_allowed": ["tenant_user"],
          "allowed_fields": ["is_archived", "client_notes"],
          "ignored_fields_behavior": "silently_ignored_and_logged",
          "logs": ["[audit.patch_ignored]", "[tenant.audit]"],
          "invariants": ["INV-1"]
        },
        { "method": "DELETE", "path": "/api/intelligence/{intel_id}", "name": "delete_intelligence", "roles_allowed": ["tenant_user", "super_admin"], "invariants": ["INV-1"] }
      ]
    },
    {
      "domain": "config",
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/config/tenants/{tenant_id}/intelligence-config",
          "name": "get_intelligence_config",
          "roles_allowed": ["super_admin"]
        },
        {
          "method": "PUT",
          "path": "/api/config/tenants/{tenant_id}/intelligence-config",
          "name": "update_intelligence_config",
          "roles_allowed": ["super_admin"]
        }
      ]
    },
    {
      "domain": "exports",
      "endpoints": [
        { "method": "POST", "path": "/api/exports/pdf", "name": "export_branded_pdf", "roles_allowed": ["tenant_user", "super_admin"], "invariants": ["INV-1", "INV-5"] },
        { "method": "POST", "path": "/api/exports/excel", "name": "export_branded_excel", "roles_allowed": ["tenant_user", "super_admin"], "invariants": ["INV-1", "INV-5"] }
      ]
    },
    {
      "domain": "chat",
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/chat/message",
          "name": "send_chat_message",
          "roles_allowed": ["tenant_user"],
          "gates": ["chat_policy.enabled", "monthly_message_limit", "max_user_chars", "conversation_id_regex"],
          "logs": ["[quota]", "[rag.audit]", "[knowledge]"],
          "invariants": ["INV-1", "INV-2", "INV-3"]
        },
        { "method": "GET", "path": "/api/chat/history/{conversation_id}", "name": "get_chat_history", "roles_allowed": ["tenant_user"], "invariants": ["INV-1"] },
        { "method": "GET", "path": "/api/chat/turns/{conversation_id}", "name": "get_chat_turns", "roles_allowed": ["tenant_user"], "invariants": ["INV-1"] }
      ]
    },
    {
      "domain": "sync",
      "endpoints": [
        { "method": "POST", "path": "/api/sync/manual/{tenant_id}", "name": "manual_sync_tenant", "roles_allowed": ["super_admin"] },
        { "method": "POST", "path": "/api/sync/opportunity/{tenant_id}", "name": "fetch_opportunity_by_id", "roles_allowed": ["super_admin"] }
      ]
    },
    {
      "domain": "upload",
      "endpoints": [
        { "method": "POST", "path": "/api/upload/logo/{tenant_id}", "name": "upload_tenant_logo", "roles_allowed": ["super_admin"], "invariants": ["INV-1"] },
        { "method": "POST", "path": "/api/upload/opportunities/csv/{tenant_id}", "name": "upload_opportunities_csv", "roles_allowed": ["super_admin"], "invariants": ["INV-1"] }
      ]
    },
    {
      "domain": "knowledge_snippets",
      "endpoints": [
        { "method": "GET", "path": "/api/tenants/{tenant_id}/knowledge-snippets", "name": "list_knowledge_snippets", "roles_allowed": ["super_admin"], "invariants": ["INV-1", "INV-4"] },
        { "method": "POST", "path": "/api/tenants/{tenant_id}/knowledge-snippets", "name": "create_knowledge_snippet", "roles_allowed": ["super_admin"], "invariants": ["INV-1", "INV-4"] },
        { "method": "PUT", "path": "/api/tenants/{tenant_id}/knowledge-snippets/{snippet_id}", "name": "update_knowledge_snippet", "roles_allowed": ["super_admin"], "invariants": ["INV-1", "INV-4"] },
        { "method": "DELETE", "path": "/api/tenants/{tenant_id}/knowledge-snippets/{snippet_id}", "name": "delete_knowledge_snippet", "roles_allowed": ["super_admin"], "invariants": ["INV-1", "INV-4"] }
      ]
    },
    {
      "domain": "rag",
      "endpoints": [
        { "method": "GET", "path": "/api/tenants/{tenant_id}/rag/status", "name": "get_rag_status", "roles_allowed": ["super_admin"], "invariants": ["INV-1", "INV-4"] },
        { "method": "GET", "path": "/api/tenants/{tenant_id}/rag/documents", "name": "list_documents", "roles_allowed": ["super_admin"], "invariants": ["INV-1", "INV-4"] },
        { "method": "POST", "path": "/api/tenants/{tenant_id}/rag/documents", "name": "ingest_document", "roles_allowed": ["super_admin"], "failures": [{ "status": 409, "when": "capacity_exceeded" }], "invariants": ["INV-1", "INV-4"] },
        { "method": "DELETE", "path": "/api/tenants/{tenant_id}/rag/documents/{doc_id}", "name": "delete_document", "roles_allowed": ["super_admin"], "invariants": ["INV-1", "INV-4"] }
      ]
    },
    {
      "domain": "system",
      "endpoints": [
        { "method": "GET", "path": "/health", "name": "health_check", "roles_allowed": ["public"] }
      ]
    }
  ],
  "integrations": [
    {
      "name": "HigherGov",
      "type": "data_ingestion",
      "code": "services/highergov_service.py",
      "purpose": "Sync contract opportunities from HigherGov saved search_id into opportunities.",
      "sync_paths": ["/api/admin/sync/{tenant_id}", "/api/sync/manual/{tenant_id}", "/api/sync/opportunity/{tenant_id}"]
    },
    {
      "name": "Perplexity",
      "type": "intelligence_generation",
      "code": "services/perplexity_service.py",
      "purpose": "Generate intelligence reports per tenant based on tenant intelligence_config."
    },
    {
      "name": "Mistral",
      "type": "llm",
      "code": ["services/mistral_service.py", "routes/chat.py", "routes/rag.py"],
      "purpose": "Opportunity scoring + chat + embeddings for RAG."
    },
    {
      "name": "APScheduler",
      "type": "scheduler",
      "code": "scheduler/sync_scheduler.py",
      "purpose": "Daily sync default and per-tenant schedules."
    }
  ],
  "frontend_pages": [
    { "path": "pages/LoginPage.js", "name": "LoginPage", "role": "both" },
    { "path": "pages/TenantDashboard.js", "name": "TenantDashboard", "role": "tenant_user" },
    { "path": "pages/IntelligenceFeed.js", "name": "IntelligenceFeed", "role": "tenant_user" },
    { "path": "pages/OpportunityDetail.js", "name": "OpportunityDetail", "role": "tenant_user" },
    { "path": "pages/TenantPreview.js", "name": "TenantPreview", "role": "tenant_user" },
    { "path": "pages/SuperAdminDashboard.js", "name": "SuperAdminDashboard", "role": "super_admin" },
    { "path": "pages/TenantsPage.js", "name": "TenantsPage", "role": "super_admin" },
    { "path": "pages/UsersPage.js", "name": "UsersPage", "role": "super_admin" },
    { "path": "pages/DatabaseManager.js", "name": "DatabaseManager", "role": "super_admin_or_internal" }
  ],
  "endpoint_count": 46
}
