FROM python:3.11-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        curl \
        jq \
        mongodb-clients \
    && rm -rf /var/lib/apt/lists/*

COPY carfax.sh ./
COPY scripts/ ./scripts/
COPY tests/ ./tests/

RUN chmod +x /app/carfax.sh

ENTRYPOINT ["./carfax.sh"]
